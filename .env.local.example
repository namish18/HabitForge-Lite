# Required for JWT session signing
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long

# Required: App login password (must be set)
APP_PASSWORD=your-secure-password

# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_your_token_here

# GitHub repository owner (your username or org)
GITHUB_OWNER=your-github-username

# GitHub repository name (private repo to use as DB)
GITHUB_REPO=habitforge-data
